class Solution:
    def subarraysDivByK(self, nums: List[int], k: int) -> int:
        current_sum = 0
        count = 0
        store={0: 1}
        for num in nums:
            current_sum = current_sum + num
            rem=current_sum % k 
            if rem  in store :
                count += store[rem]    
                store[rem] += 1
            else:
                store[rem] = 1
            
        return count 

